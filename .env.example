# ─── Server Environment ───────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it contains secrets.

# ── Port ─────────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Option A — MongoDB Atlas (production):
#   1. Go to https://cloud.mongodb.com → Database Access → your user → edit → copy password
#   2. Replace <db_password> below with your actual password
# MONGO_URI=mongodb+srv://tejasbariya22_db_user:<db_password>@mtalk-db.w6jesq2.mongodb.net/mtalk?retryWrites=true&w=majority&appName=mtalk-db

# Option B — Local MongoDB (development, default):
MONGO_URI=mongodb://127.0.0.1:27017/mtalk

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_strong_random_secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT:
#   CLIENT_URL=http://localhost:5173

# PRODUCTION (Vercel frontend) — set this in Render environment variables:
#   CLIENT_URL=https://your-app-name.vercel.app
CLIENT_URL=http://localhost:5173

# ── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV=development
